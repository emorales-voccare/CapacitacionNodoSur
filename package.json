{
  "name": "capacitacion-nodo-sur",
  "version": "1.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node --disable-warning=ExperimentalWarning --watch server/index.js",
    "client": "npm --prefix client run dev",
    "install:all": "npm install && npm --prefix client install",
    "build": "npm --prefix client install --include=dev && npm --prefix client run build",
    "start": "node server/index.js"
  },
  "devDependencies": {
    "dotenv": "^16.4.7"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "pg": "^8.13.3",
    "googleapis": "^144.0.0"
  }
}
